  file_size      String
  file_public_id String
  file_url       String
  signatory      Json[]
  timestamp      DateTime @default(now())
  lineId         String?
  section        Int      @default(0)
  line           Line?    @relation(fields: [lineId], references: [id], onDelete: Cascade)
}

model ProfileView {
  id           String   @id @default(uuid())
  userId       String
  targetUserId String?
  desc         String?
  descryption  Boolean
  timestamp    DateTime @default(now())
  targetUser   User?    @relation("targetUser", fields: [targetUserId], references: [id])
  viewingBy    User     @relation("viewingBy", fields: [userId], references: [id])
}
