/// Generic offline-first sync store for the Gasan Pharmacy desktop app.
/// One row per (tableName, recordId) where recordId is the client-generated
/// UUID of the local row — so re-pushing the same record is an idempotent
/// upsert (this is the duplication guard). `payload` holds the full local
/// row as JSON; `updatedAt` is the client's domain timestamp (last-write-wins);
/// `serverAt` is the server change time used as the pull cursor; `deletedAt`
/// carries soft-delete tombstones. Scoped per line so each LGU only syncs
/// its own pharmacy data.
model SyncRecord {
  id        String    @id @default(uuid())
  tableName String
  recordId  String
  lineId    String?
  payload   Json
  updatedAt DateTime
  deletedAt DateTime?
  serverAt  DateTime  @default(now()) @updatedAt

  @@unique([tableName, recordId])
  @@index([tableName, lineId, serverAt])
}

// ── Employee chat ─────────────────────────────────────────────────────────
// Three fixed rooms per line: "community" (everyone posts), "hr" (HR-module
// users post, everyone reads) and "mayor" (super-privilege users post, everyone
// reads). Self-contained (ids are plain strings, sender name denormalised) so no
// other model needs editing.
model ChatMessage {
  id             String   @id @default(uuid())
  lineId         String
  room           String // "community" | "hr" | "mayor"
  senderId       String // User.id
  senderName     String?
  body           String?
  imageId        String? // -> ChatImage.id
  fileId         String? // -> ChatFile.id (any document)
  fileName       String? // original filename (denormalised for display)
  fileSize       Int? // bytes (denormalised for display)
  linkUrl        String?
  mentionUserIds String[] // mentioned User.ids
  mentionNames   String[] // matching display names (so clients can highlight exactly)
  replyToId      String? // ChatMessage.id this message is replying to
  replyToName    String? // denormalised sender name of the replied message
  replyToPreview String? // denormalised short preview of the replied message
  linkTitle      String? // OG title for the first link (preview card)
  linkDesc       String? // OG description for the preview card
  linkImage      String? // OG image URL for the preview card
  clientOpId     String?  @unique
  editedAt       DateTime? // set when the sender edits the body
  deletedAt      DateTime? // "delete for everyone" tombstone (content cleared)
  createdAt      DateTime @default(now())

  @@index([lineId, room, createdAt])
  @@index([senderId])
}

model ChatReadState {
  id         String   @id @default(uuid())
  userId     String
  lineId     String
  room       String
  lastReadAt DateTime @default(now())
  muted      Boolean  @default(false) // per-user: silence this room's push

  @@unique([userId, lineId, room])
}

model ChatImage {
  id        String   @id @default(uuid())
  mime      String
  bytes     Bytes
  createdAt DateTime @default(now())
}

// Any attached document (PDF, Word, Excel, …). Keeps the original filename +
// size so the bubble can show "📎 report.pdf (1.2 MB)".
model ChatFile {
  id        String   @id @default(uuid())
  name      String
  mime      String
  size      Int
  bytes     Bytes
  createdAt DateTime @default(now())
}

// One reaction per user per message (picking a new emoji replaces it; picking
// the same one again removes it — Messenger-style).
model ChatReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

// A user-submitted report on a message (spam/abuse). HR/super see these.
model ChatReport {
  id           String   @id @default(uuid())
  lineId       String
  room         String
  messageId    String
  reporterId   String
  reporterName String?
  reason       String?
  createdAt    DateTime @default(now())

  @@index([lineId, createdAt])
  @@index([messageId])
}

// Last-seen presence per user. Online/offline is tracked in-memory by the
// socket; this table only persists the last time each user was connected so
// offline members can show "last seen 5m ago".
model ChatPresence {
  userId     String   @id
  lineId     String
  lastSeenAt DateTime @default(now())

  @@index([lineId])
}
