model FillPositionInvitation {
  id                     String                @id @default(uuid())
  email                  String
  message                String?
  concluded              Boolean               @default(false)
  concludedAt            DateTime?
  /// Why the invitation was concluded (auto-set when concluded=true).
  ///   "accepted"  → applicant registered + submitted
  ///   "cancelled" → HR revoked the invite from the dashboard
  ///   "expired"   → expiresAt passed, surfaced lazily on read
  concludedReason        String?
  /// 7 days from creation by default. Read-time filters can compare to
  /// `now()` to treat anything past as expired.
  expiresAt              DateTime?
  timestamp              DateTime              @default(now())
  unitPositionId         String?
  lineId                 String
  positionSlotId         String?
  step                   Int                   @default(0)
  /// Provisional hiring: the chosen unit (departmentId) + the ProvisionalPosition.
  /// empType is denormalized from the position for invite lists; the contract
  /// end date (User.term) is computed at register from position.termMonths.
  empType                String?
  term                   DateTime?
  provisionalPositionId  String?
  departmentId           String?
  submittedApplicationId String?               @unique
  line                   Line                  @relation(fields: [lineId], references: [id], onDelete: SetDefault)
  slot                   PositionSlot?         @relation(fields: [positionSlotId], references: [id], onDelete: SetDefault)
  applcation             SubmittedApplication? @relation(fields: [submittedApplicationId], references: [id])
  unitPoistion           UnitPosition?         @relation(fields: [unitPositionId], references: [id])
  provisionalPosition    ProvisionalPosition?  @relation(fields: [provisionalPositionId], references: [id])
  department             Department?           @relation("ProvisionalInvites", fields: [departmentId], references: [id])
}

/// A temporary/contract position (Job Order, Contract of Service, Casual, etc.)
/// with a fixed term in months. NOT tied to a unit — HR picks the unit when
/// hiring each applicant. `slots` is the number of openings.
model ProvisionalPosition {
  id            String                   @id @default(uuid())
  title         String
  empType       String
  termMonths    Int                      @default(3)
  slots         Int                      @default(1)
  description   String?
  lineId        String
  salaryGradeId String?
  createdAt     DateTime                 @default(now())
  line          Line                     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  salaryGrade   SalaryGrade?             @relation(fields: [salaryGradeId], references: [id])
  invitations   FillPositionInvitation[]
}

