// ─── Leave management ────────────────────────────────────────────────
// `category` carries the canonical leave kind ("vacation" | "sick" |
// "mandatory" | "maternity" | "paternity" | "soloParent" |
// "specialPrivilege" | "bereavement" | "emergency" | "others"). `type`
// is preserved for backward compatibility with older callers.
// `status` enum: "pending" | "approved" | "denied" | "cancelled".
model Leave {
  id             String        @id @default(uuid())
  userId         String
  lineId         String?
  type           String
  category       String        @default("vacation")
  withPay        Boolean       @default(true)
  days           Float         @default(0)
  startDate      DateTime
  endDate        DateTime
  reason         String?
  attachmentUrl  String?
  attachmentType String?
  status         String        @default("pending")
  approverId     String?
  decidedAt      DateTime?
  decisionRemark String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: SetDefault)
  approver       User?         @relation("LeaveApprover", fields: [approverId], references: [id])
  line           Line?         @relation(fields: [lineId], references: [id], onDelete: SetNull)
  ledger         LeaveLedger[]

  @@index([userId, status])
  @@index([lineId, status, createdAt])
}

// Per-user, per-category, per-year credit bucket. Updated by ledger
// entries (accrual, usage, refund, adjustment) so balance is always
// auditable.
model LeaveCredit {
  id        String   @id @default(uuid())
  userId    String
  lineId    String?
  category  String
  year      Int
  accrued   Float    @default(0)
  used      Float    @default(0)
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  line      Line?    @relation(fields: [lineId], references: [id], onDelete: SetNull)

  @@unique([userId, category, year])
}

// Append-only ledger for any change to a user's leave credits.
// `kind` ∈ "accrual" | "usage" | "refund" | "adjustment".
model LeaveLedger {
  id       String   @id @default(uuid())
  userId   String
  category String
  year     Int
  delta    Float
  kind     String
  note     String?
  leaveId  String?
  byUserId String?
  at       DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leave    Leave?   @relation(fields: [leaveId], references: [id], onDelete: SetNull)
  by       User?    @relation("LeaveLedgerBy", fields: [byUserId], references: [id])

  @@index([userId, category, year])
}

// ─── Payroll ─────────────────────────────────────────────────────────
// Period status: "draft" | "computed" | "released".
model PayrollPeriod {
  id              String    @id @default(uuid())
  lineId          String
  label           String
  periodStart     DateTime
  periodEnd       DateTime
  status          String    @default("draft")
  computedAt      DateTime?
  releasedAt      DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  line            Line      @relation(fields: [lineId], references: [id], onDelete: Cascade)
  createdBy       User?     @relation("PayrollPeriodCreatedBy", fields: [createdByUserId], references: [id])
  payslips        Payslip[]

  @@index([lineId, periodStart])
}

// One per user per period. All monetary fields stored in pesos (Float).
model Payslip {
  id              String        @id @default(uuid())
  userId          String
  periodId        String
  lineId          String
  salaryGradeId   String?
  basicMonthly    Float         @default(0)
  workingDays     Float         @default(0)
  daysAbsent      Float         @default(0)
  paidLeaveDays   Float         @default(0)
  unpaidLeaveDays Float         @default(0)
  grossPay        Float         @default(0)
  sssEE           Float         @default(0)
  philhealthEE    Float         @default(0)
  pagibigEE       Float         @default(0)
  withholdingTax  Float         @default(0)
  otherDeductions Float         @default(0)
  netPay          Float         @default(0)
  breakdown       Json?
  status          String        @default("computed")
  computedAt      DateTime      @default(now())
  releasedAt      DateTime?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  period          PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  line            Line          @relation(fields: [lineId], references: [id], onDelete: Cascade)
  salaryGrade     SalaryGrade?  @relation(fields: [salaryGradeId], references: [id])

  @@unique([userId, periodId])
  @@index([lineId, periodId])
}

// ─── Services (employee-self-service) ─────────────────────────────────
// `category` ∈ "general" | "hr" | "facilities" | "it" | "payroll" | "safety"
// `status`   ∈ "open" | "in_progress" | "resolved" | "closed"
// `priority` ∈ "low" | "normal" | "high"
model Complaint {
  id               String              @id @default(uuid())
  userId           String
  againstUserId    String?
  lineId           String
  title            String
  category         String              @default("general")
  description      String
  attachmentUrl    String?
  attachmentType   String?
  status           String              @default("open")
  priority         String              @default("normal")
  assignedToUserId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  resolvedAt       DateTime?
  user             User                @relation("ComplaintAuthor", fields: [userId], references: [id], onDelete: Cascade)
  againstUser      User?               @relation("ComplaintAgainst", fields: [againstUserId], references: [id])
  line             Line                @relation(fields: [lineId], references: [id], onDelete: Cascade)
  assignedTo       User?               @relation("ComplaintAssignee", fields: [assignedToUserId], references: [id])
  replies          ComplaintReply[]
  evidence         ComplaintEvidence[]

  @@index([lineId, status, createdAt])
  @@index([userId, createdAt])
  @@index([againstUserId, createdAt])
}

// Files uploaded as evidence. Bytes stored in-row (matching the existing
// DecodedFile pattern) so we don't need separate object storage. Caller
// streams them back via the `/service/complaint/evidence/file` endpoint.
model ComplaintEvidence {
  id           String    @id @default(uuid())
  complaintId  String
  fileName     String
  fileType     String
  fileSize     Int
  data         Bytes
  uploadedById String?
  caption      String?
  createdAt    DateTime  @default(now())
  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id])
}

model ComplaintReply {
  id          String    @id @default(uuid())
  complaintId String
  userId      String
  content     String
  internal    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
}

// Custom deduction rules (loans, uniforms, etc.). When periodId is null
// the deduction is recurring and applied to every period the user is in.
model PayrollDeduction {
  id        String   @id @default(uuid())
  userId    String
  lineId    String
  periodId  String?
  label     String
  amount    Float
  recurring Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  line      Line     @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@index([userId, recurring])
}

model Announcement {
  id                      String                   @id @default(uuid())
  title                   String
  content                 String
  createdAt               DateTime                 @default(now())
  authorId                String
  lineId                  String
  departmentId            String?
  important               Boolean                  @default(true)
  path                    String?
  status                  Int                      @default(1)
  contentIv               String?
  titleIv                 String?
  author                  User                     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  unit                    Department?              @relation(fields: [departmentId], references: [id])
  line                    Line                     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  announcementAttachFiles AnnouncementAttachFile[]
  announcementMentions    AnnouncementMentions[]
  announcementReactions   AnnouncementReaction[]
  announcementViews       AnnouncementViews[]
}

model AnnouncementReaction {
  id             String       @id @default(uuid())
  userId         String?
  announcementId String
  reaction       Int          @default(0)
  timestamp      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])
}

model AnnouncementViews {
  id             String        @id @default(uuid())
  userId         String?
  announcementId String?
  timestamp      DateTime      @default(now())
  announcement   Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnnouncementMentions {
  id             String       @id @default(uuid())
  announcementId String
  userId         String?
  timestamp      DateTime?    @default(now())
  departmentId   String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  department     Department   @relation(fields: [departmentId], references: [id], onDelete: SetDefault)
  user           User?        @relation(fields: [userId], references: [id])
}

model AnnouncementAttachFile {
  id             String       @id @default(uuid())
  file_name      String
  file_size      String
  file_type      String
  file_public_id String
  file_url       String
  timestamp      DateTime     @default(now())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
}

model Promotion {
  id         String   @id @default(uuid())
  userId     String
  timestamp  DateTime @default(now())
  positionId String
  postion    Position @relation(fields: [positionId], references: [id])
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BirthdayNoticeResponse {
  id          String   @id @default(uuid())
  message     String?
  like        Boolean  @default(false)
  timestamp   DateTime @default(now())
  senderId    String
  recipientId String?
  lineId      String
  line        Line     @relation(fields: [lineId], references: [id])
  Recipient   User?    @relation("Recipient", fields: [recipientId], references: [id])
  Sender      User     @relation("Sender", fields: [senderId], references: [id])
}

model Region {
  id       String     @id
  name     String
  Line     Line[]
  provices Province[]
  User     User[]
  patience Patient[]
}

model Province {
  id           String         @id
  name         String
  regionId     String?
  Line         Line[]
  municipals   Municipal[]
  Prescription Prescription[]
  Region       Region?        @relation(fields: [regionId], references: [id])
  User         User[]
  patience     Patient[]
}

model Municipal {
  id           String         @id
  name         String
  provinceId   String?
  barangays    Barangay[]
  Line         Line[]
  Province     Province?      @relation(fields: [provinceId], references: [id])
  Prescription Prescription[]
  User         User[]
  patience     Patient[]
}

model Barangay {
  id           String         @id
  name         String
  municipalId  String?
  Municipal    Municipal?     @relation(fields: [municipalId], references: [id])
  Line         Line[]
  Prescription Prescription[]
  User         User[]
  patience     Patient[]
}

model Accomplishment {
  id                     String                   @id @default(uuid())
  timestamp              DateTime                 @default(now())
  userId                 String?
  start                  DateTime
  end                    DateTime
  task                   String
  user                   User?                    @relation(fields: [userId], references: [id])
  AccomplishmentResponse AccomplishmentResponse[]
}

model AccomplishmentResponse {
  id               String         @id @default(uuid())
  headId           String
  accomplishmentId String
  message          String
  timestamp        DateTime       @default(now())
  accomplishment   Accomplishment @relation(fields: [accomplishmentId], references: [id])
  head             User           @relation("Head", fields: [headId], references: [id])
}

model RoomRegistration {
  id                            String                           @id @default(uuid())
  address                       String
  userId                        String
  status                        Int                              @default(0)
  dateApproved                  DateTime?
  dateRejected                  DateTime?
  lastApprovedDate              DateTime?
  timestamp                     DateTime                         @default(now())
  lineId                        String
  line                          Line                             @relation(fields: [lineId], references: [id], onDelete: Cascade)
  user                          User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorizedUser                RoomRegistrationAuthorizedUser[]
  roomRegistrationConversations RoomRegistrationConversation[]
  roomRegistrationSignatures    RoomRegistrationSignature?
}

model RoomRegistrationSignature {
  id                 String            @id @default(uuid())
  file_name          String?
  file_size          String?
  file_type          String?
  file_public_id     String?
  file_url           String?
  roomRegistrationId String?           @unique
  timestamp          DateTime          @default(now())
  roomRegistration   RoomRegistration? @relation(fields: [roomRegistrationId], references: [id], onDelete: Cascade)
}

model RoomRegistrationAuthorizedUser {
  id                 String           @id @default(uuid())
  roomRegistrationId String
  nickname           String?
  userId             String
  status             Int              @default(0)
  timestamp          DateTime         @default(now())
  type               Int
  roomRegistration   RoomRegistration @relation(fields: [roomRegistrationId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id])
}

model RoomRegistrationConversation {
  id                 String           @id @default(uuid())
  seen               Boolean          @default(false)
  mesasge            String
  timestamp          DateTime         @default(now())
  fromUserId         String
  toUserId           String
  roomRegistrationId String
  from               User             @relation("RoomRegistrationConversationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  roomRegistration   RoomRegistration @relation(fields: [roomRegistrationId], references: [id], onDelete: Cascade)
  to                 User             @relation("RoomRegistrationConversationTo", fields: [toUserId], references: [id], onDelete: Cascade)
}

model ReceivingRoom {
  id                   String               @id @default(uuid())
  code                 String               @unique
  address              String?
  receivedMarkFileId   String?              @unique
  timestamp            DateTime             @default(now())
  signatureQueueRoomId String?
  lineId               String
  status               Int                  @default(1)
  archiveDocument      ArchiveDocument[]
  documents            Document[]
  line                 Line                 @relation(fields: [lineId], references: [id], onDelete: Cascade)
  marker               ReceivedMarkFile?    @relation(fields: [receivedMarkFileId], references: [id])
  authorizedUser       RoomAuthorizedUser[]
  targetRooms          TargetRoom[]
  signatureQueueRooms  SignatureQueueRoom[]
}

model RoomAuthorizedUser {
  id              String         @id @default(uuid())
  type            Int            @default(0)
  userId          String?
  status          Int            @default(1)
  timestamp       DateTime       @default(now())
  receivingRoomId String?
  receivingRoom   ReceivingRoom? @relation(fields: [receivingRoomId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id])
  signature       Signature[]
}

model ReceivedMarkFile {
  id             String         @id @default(uuid())
  title          String?
  status         Int            @default(1)
  file_uri       String
  file_public_id String?
  file_name      String?
  file_size      String?
  timestamp      DateTime       @default(now())
  departmentId   String
  unit           Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  receivingRooms ReceivingRoom?
}

model ArchiveDocument {
  id                    String               @id @default(uuid())
  status                Int                  @default(1)
  documentId            String?              @unique
  lineId                String?
  timestamp             DateTime             @default(now())
  receivingRoomId       String?
  documentAbstractId    String?              @unique
  detentionDate         DateTime?
  retentionDate         DateTime?
  docType               Int                  @default(0)
  archivePreservationId String?              @unique
  preservation          ArchivePreservation? @relation(fields: [archivePreservationId], references: [id])
  abstract              DocumentAbstract?    @relation(fields: [documentAbstractId], references: [id])
  document              Document?            @relation(fields: [documentId], references: [id])
  line                  Line?                @relation(fields: [lineId], references: [id], onDelete: Cascade)
  receivingRoom         ReceivingRoom?       @relation(fields: [receivingRoomId], references: [id])
}

model ArchivePreservation {
  id               String           @id @default(uuid())
  type             Int              @default(1)
  retentionDate    DateTime?
  detentionDate    DateTime?
  safeDate         DateTime?
  dateUpdated      DateTime?
  timestamp        DateTime         @default(now())
  archiveDocuments ArchiveDocument?
}

model Document {
  id                   String                 @id @default(uuid())
  type                 Int                    @default(0)
  size                 Int                    @default(0)
  orientation          Int                    @default(1)
  status               Int                    @default(0)
  title                String?
  timestamp            DateTime               @default(now())
  userId               String?
  signatureQueueRoomId String?
  lineId               String
  docType              Int                    @default(0)
  receivingRoomId      String?
  original             Int                    @default(0)
  archiveDocuments     ArchiveDocument?
  file                 DecodedFile?
  line                 Line                   @relation(fields: [lineId], references: [id], onDelete: Cascade)
  receivingRoom        ReceivingRoom?         @relation(fields: [receivingRoomId], references: [id])
  signatureQueueRoom   SignatureQueueRoom?    @relation(fields: [signatureQueueRoomId], references: [id])
  user                 User?                  @relation(fields: [userId], references: [id])
  documentActivityLogs DocumentActivityLogs[]
  documentDuplicates   DocumentDuplicate[]
  pages                DocumentPage[]
  submittedDocuments   SubmittedDocument?
}

model SubmittedDocument {
  id          String       @id @default(uuid())
  status      Int          @default(0)
  documentId  String?      @unique
  timestamp   DateTime     @default(now())
  userId      String?
  document    Document?    @relation(fields: [documentId], references: [id])
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  submittedTo TargetRoom[]
}

model DocumentDuplicate {
  id         String   @id @default(uuid())
  documentId String
  number     Int      @default(0)
  timestamp  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id])
}

model DocumentPage {
  id         String          @id @default(uuid())
  page       Int             @default(1)
  title      String?
  content    String
  documentId String?
  timestamp  DateTime        @default(now())
  document   Document?       @relation(fields: [documentId], references: [id])
  signCoor   SignatureCoor[]
}

// A physical document logged by receiving personnel: a barcode sticker is
// attached to the paper, then scanned (mobile) or typed (web). The barcode is
// the lookup key and is unique per line. Sender is either a unit (Department)
// of the line or a free-text name for outside senders.
model DocumentReceiveRecord {
  id             String    @id @default(uuid())
  lineId         String
  barcode        String
  title          String
  senderUnitId   String? // Department.id when the sender is a unit in the line
  senderUnitName String? // denormalised so mobile/offline can render without a join
  senderName     String? // free-text sender (walk-in / external)
  receivedById   String? // User.id of the receiving personnel
  receivedByName String? // denormalised for display
  direction      String    @default("in") // "in" (received) | "out" (released)
  clientOpId     String?   @unique // mobile offline-create idempotency key
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@unique([lineId, barcode])
  @@index([lineId, updatedAt])
}

// A scanned page image attached to a DocumentReceiveRecord — captured with
// the mobile document scanner (VisionKit / ML Kit). Bytes live in the DB,
// same storage pattern as ChatImage. `id` is client-suppliable so the
// offline upload queue is idempotent.
model DocumentReceivePage {
  id        String   @id @default(uuid())
  recordId  String
  page      Int      @default(1)
  mime      String
  bytes     Bytes
  createdAt DateTime @default(now())

  @@index([recordId, page])
}

model DocumentAbstract {
  id               String            @id @default(uuid())
  title            String
  content          String
  timestamp        DateTime          @default(now())
  archiveDocuments ArchiveDocument?
  embedding        ArchiveEmbedding?
}

model ArchiveEmbedding {
  id                 String           @id @default(uuid())
  documentAbstractId String           @unique
  documentAbstract   DocumentAbstract @relation(fields: [documentAbstractId], references: [id], onDelete: Cascade)
  model              String // "all-MiniLM-L6-v2", etc.
  dimensions         Int // 384
  vector             Json // The embedding array
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([documentAbstractId])
  @@index([model])
}

model DecodedFile {
  id          String    @id @default(uuid())
  fileName    String
  fileSize    String
  fileType    String
  fileDecoded Bytes?
  timestamp   DateTime  @default(now())
  documentId  String?   @unique
  document    Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model UserKeyPair {
  id         String   @id @default(uuid())
  userId     String   @unique
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model Signature {
  id                   String              @id @default(uuid())
  title                String
  defalt               Boolean             @default(false)
  timestamp            DateTime            @default(now())
  userId               String
  forRenew             DateTime?
  active               Boolean             @default(false)
  roomAuthorizedUserId String?
  signature            Bytes?
  // Per-signature toggle: when true, downloaded signed PDFs stamp a
  // verification QR beside any box that used THIS signature.
  qrEnabled            Boolean             @default(false)
  roomAuthorizedUser   RoomAuthorizedUser? @relation(fields: [roomAuthorizedUserId], references: [id])
  user                 User                @relation(fields: [userId], references: [id])
  arrangements         SignatoryArrangement[]
}

model SignatoryArrangement {
  id                   String              @id @default(uuid())
  index                Int                 @default(0)
  status               Int                 @default(0)
  signedAt             DateTime?
  timestamp            DateTime            @default(now())
  signatureQueueRoomId String?
  userId               String?
  // Geolocation captured from the browser at sign time. Used by the
  // verification QR — the QR payload is a URL to a readable HTML page
  // that shows these values + a Google Maps link.
  signedLat            Float?
  signedLng            Float?
  signedAccuracy       Float?
  // The signature the signer chose at sign time. Null = use the signer's
  // active signature at download time (legacy behavior).
  signatureId          String?
  signatureQueueRoom   SignatureQueueRoom? @relation(fields: [signatureQueueRoomId], references: [id], onDelete: Cascade)
  user                 User?               @relation("SignatoryArrangementUser", fields: [userId], references: [id])
  chosenSignature      Signature?          @relation(fields: [signatureId], references: [id])
  sign                 SignatureCoor[]
}

model SignatureQueueRoom {
  id                   String                       @id @default(uuid())
  userId               String
  departmentId         String?
  timestamp            DateTime                     @default(now())
  status               Int                          @default(0)
  step                 Int                          @default(0)
  title                String?
  index                Int                          @default(0)
  documents            Document[]
  signatotyArrangement SignatoryArrangement[]
  unit                 Department?                  @relation(fields: [departmentId], references: [id], onDelete: SetDefault)
  user                 User                         @relation(fields: [userId], references: [id])
  endorser             SignatureQueueRoomApprover[]
  targetRooms          TargetRoom[]
  fromRoom             ReceivingRoom?               @relation(fields: [receivingRoomId], references: [id], onDelete: SetNull)
  receivingRoomId      String?
}

model TargetRoom {
  id                   String              @id @default(uuid())
  signatureQueueRoomId String?
  timestamp            DateTime            @default(now())
  receivingRoomId      String?
  status               Int                 @default(0)
  receivedAt           DateTime?
  submittedDocumentId  String?
  roomReceiver         ReceivingRoom?      @relation(fields: [receivingRoomId], references: [id])
  queueRoom            SignatureQueueRoom? @relation(fields: [signatureQueueRoomId], references: [id])
  submittedDocuments   SubmittedDocument?  @relation(fields: [submittedDocumentId], references: [id])
}

model DocumentRoute {
  id            String          @id @default(uuid())
  name          String?
  parentRouteId String?
  parentRoute   DocumentRoute?  @relation("RouteHierarchy", fields: [parentRouteId], references: [id])
  childRoutes   DocumentRoute[] @relation("RouteHierarchy")
}

model SignatureQueueRoomApprover {
  id                   String              @id @default(uuid())
  userId               String
  timestamp            String
  signatureQueueRoomId String?
  SignatureQueueRoom   SignatureQueueRoom? @relation(fields: [signatureQueueRoomId], references: [id])
  user                 User                @relation(fields: [userId], references: [id])
}

model SignatureCoor {
  id                     String                @id @default(uuid())
  xAxis                  Int
  yAxis                  Int
  width                  Int
  height                 Int
  timestamp              DateTime              @default(now())
  signatureRequestId     String?
  documentPageId         String?
  signatoryArrangementId String?
  documentPage           DocumentPage?         @relation(fields: [documentPageId], references: [id])
  signatoryArrangement   SignatoryArrangement? @relation(fields: [signatoryArrangementId], references: [id])
  SignatureRequest       SignatureRequest?     @relation(fields: [signatureRequestId], references: [id])
}

model SignatureRecord {
  id                 String           @id @default(uuid())
  signatureRequestId String
  lineId             String
  signature          String
  userId             String
  timestamp          DateTime         @default(now())
  request            SignatureRequest @relation(fields: [signatureRequestId], references: [id])
}

model SignatureRequest {
  id              String            @id @default(uuid())
  subject         String
  desc            String?           @default("N/A")
