/**
 * Idempotency log for mobile bulk uploads. Each row tracks a single
 * client-generated `clientOpId` (UUID minted on the mobile when the user
 * fills in the Add Stock form, captured in the local `stock_add_queue`
 * table). The backend uses this to dedupe retries — if the mobile lost
 * a response and replays the same op, we recognise the id and short-
 * circuit with the previous result instead of writing stock twice.
 *
 * The `kind` column lets the same table cover other queueable mobile
 * operations later (medicine scan log, etc.) without a new model.
 */
model MobileUploadLog {
  id          String   @id @default(uuid())
  clientOpId  String   @unique
  kind        String
  userId      String?
  lineId      String?
  /** Foreign id the op produced (e.g. MedicineStock.id) — useful for
   *  reporting back "your op landed on row X" on a replay. */
  resultId    String?
  message     String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([kind])
}

