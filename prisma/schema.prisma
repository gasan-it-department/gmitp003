/**
 * Push-notification token registered by a mobile device (Expo Push token,
 * one per device + user). Used to deliver OS-level pushes when the app is
 * closed or backgrounded. Multiple rows per user supported: one phone,
 * one tablet, etc. The unique constraint on `token` lets us upsert
 * without first looking up.
 */
model PushToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  platform   String?
  deviceName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

