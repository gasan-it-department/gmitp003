generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Line {
  id                      String                    @id @default(uuid())
  name                    String                    @unique
  barangayId              String
  municipalId             String
  provinceId              String
  regionId                String
  createdAt               DateTime                  @default(now())
  status                  Int                       @default(1)
  adminProfileId          String?
  password                String?
  email                   String?
  phoneNumber             String?
  telephoneNumber         String?
  userId                  String?                   @unique
  hrmoEmail               String?
  hrmoTelePhone           String?
  Account                 Account[]
  activityLogs            ActivityLogs[]
  Announcement            Announcement[]
  applications            Application[]
  ApplicationConversation ApplicationConversation[]
  ApplicationResponse     ApplicationResponse[]
  archiveDocuments        ArchiveDocument[]
  BirthdayNoticeResponse  BirthdayNoticeResponse[]
  Department              Department[]
  documents               Document[]
  documentActivityLogs    DocumentActivityLogs[]
  fillPositionInvitations FillPositionInvitation[]
  provisionalPositions    ProvisionalPosition[]
  Group                   Group[]
  HumanResourcesLogs      HumanResourcesLogs[]
  InventoryBox            InventoryBox[]
  InventoryInboxItems     InventoryInboxItems[]
  inventoryLogs           InventoryLogs[]
  InvitationLink          InvitationLink[]
  jobPosts                JobPost[]
  AdminProfile            AdminProfile?             @relation(fields: [adminProfileId], references: [id])
  barangay                Barangay                  @relation(fields: [barangayId], references: [id])
  municipal               Municipal                 @relation(fields: [municipalId], references: [id])
  province                Province                  @relation(fields: [provinceId], references: [id])
  region                  Region                    @relation(fields: [regionId], references: [id])
  hrmo                    User?                     @relation("hrmo", fields: [userId], references: [id])
  lineGeneralAssets       LineGeneralAssets[]
  lineInvitations         LineInvitation?
  Medicine                Medicine[]
  MedicineLogs            MedicineLogs[]
  MedicineNotification    MedicineNotification[]
  MedicineStock           MedicineStock[]
  MedicineStorage         MedicineStorage[]
  MedicineTransaction     MedicineTransaction[]
  PharmacyMobileAccess    PharmacyMobileAccess[]
  DocumentMobileAccess    DocumentMobileAccess[]
  MessageTemplate         MessageTemplate[]
  modules                 Module[]
  Position                Position[]
  Prescription            Prescription[]
  receivingRooms          ReceivingRoom[]
  roomRegistrations       RoomRegistration[]
  SalaryGrade             SalaryGrade[]
  SubmittedApplication    SubmittedApplication[]
  Supplier                Supplier[]
  Supplies                Supplies[]
  SuppliesDataSet         SuppliesDataSet[]
  SupplyBatchOrder        SupplyBatchOrder[]
  supplyTransactions      SupplyTransaction[]
  supplytExcelExports     SupplytExcelExport[]
  unitPositions           UnitPosition[]
  User                    User[]
  patients                Patient[]
  leaves                  Leave[]
  leaveCredits            LeaveCredit[]
  payrollPeriods          PayrollPeriod[]
  payslips                Payslip[]
  payrollDeductions       PayrollDeduction[]
  complaints              Complaint[]
}

model LineInvitation {
  id                     String                @id @default(uuid())
  email                  String?
  lineId                 String?               @unique
  status                 Int                   @default(0)
  timestamp              DateTime              @default(now())
  positionSlotId         String
  submittedApplicationId String?               @unique
  unitPositionId         String
  line                   Line?                 @relation(fields: [lineId], references: [id], onDelete: Cascade)
  posSlot                PositionSlot          @relation(fields: [positionSlotId], references: [id])
  application            SubmittedApplication? @relation(fields: [submittedApplicationId], references: [id])
  unitPosition           UnitPosition          @relation(fields: [unitPositionId], references: [id])
}

model AdminLogs {
  id        String   @id @default(uuid())
  adminId   String
  action    Int      @default(0)
  desc      String?
  timestamp DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id])
}

model ActivityLogs {
  id        String   @id @default(uuid())
  userId    String
  action    Int      @default(0)
  desc      String?
  timestamp DateTime @default(now())
  lineId    String
  line      Line     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvitationLink {
  id        String    @id @default(uuid())
  code      String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  used      Boolean   @default(false)
  url       String
  lineId    String
  status    Int       @default(1)
  message   String?
  line      Line      @relation(fields: [lineId], references: [id], onDelete: Cascade)
}

model Assets {
  id                 String                   @id @default(uuid())
  url                String
  fileSize           String
  fileType           String
  fileName           String
  createdAt          DateTime                 @default(now())
  suppliesId         String?
  Supplies           Supplies?                @relation(fields: [suppliesId], references: [id])
  ProfilePicture     ProfilePicture[]
  SupplyOrderSupport SupplyOrderSupportFile[]
}

model ProfilePicture {
  id        String   @id @default(uuid())
  assetsId  String
  userId    String   @unique
  createdAt DateTime @default(now())
  asset     Assets   @relation(fields: [assetsId], references: [id])
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InventoryBox {
  id                      String                  @id @default(uuid())
  /// Name is unique *within* a line — two different lines can each have
  /// an "Office Supplies" container without colliding.
  name                    String
  code                    Int                     @unique
  createdAt               DateTime                @default(now())
  lineId                  String
  userId                  String
  departmentId            String?
  ContainerAllowedUser    ContainerAllowedUser[]
  InventoryAccessLogs     InventoryAccessLogs[]
  unit                    Department?             @relation(fields: [departmentId], references: [id])
  line                    Line                    @relation(fields: [lineId], references: [id])
  createdBy               User                    @relation("createdBy", fields: [userId], references: [id])
  supplieRecieveHistories SupplieRecieveHistory[]
  supplies                Supplies[]
  SuppliesDataSet         SuppliesDataSet[]
  SupplyBatch             SupplyBatch[]
  batch                   SupplyBatchOrder[]
  supplyDispenseRecords   SupplyDispenseRecord[]
  SupplyStockTrack        SupplyStockTrack[]
  supplyTransactions      SupplyTransaction[]

  @@unique([lineId, name])
  @@index([lineId])
  @@index([departmentId])
}

model InventoryInbox {
  id String @id @default(uuid())
}

model InventoryInboxItems {
  id        String   @id @default(uuid())
  view      Boolean  @default(false)
  type      Int      @default(0)
  message   String?
  subject   String?
  path      String?
  timestamp DateTime @default(now())
  lineId    String
  line      Line     @relation(fields: [lineId], references: [id])
}

model ContainerAllowedUser {
  id             String       @id @default(uuid())
  userId         String?
  inventoryBoxId String
  grantByUserId  String
  timestamp      DateTime     @default(now())
  grantBy        User         @relation("GrantBy", fields: [grantByUserId], references: [id])
  container      InventoryBox @relation(fields: [inventoryBoxId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])
}

model InventoryLogs {
  id        String   @id @default(uuid())
  userId    String
  action    Int      @default(0)
  lineId    String
  timestamp DateTime @default(now())
  desc      String?  @default("N/A")
  line      Line     @relation(fields: [lineId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model InventoryAccessLogs {
  id             String        @id @default(uuid())
  userId         String?
  timestamp      DateTime      @default(now())
  inventoryBoxId String?
  action         String        @default("Viewed")
  suppliesId     String?
  path           String?
  box            InventoryBox? @relation(fields: [inventoryBoxId], references: [id])
  supply         Supplies?     @relation(fields: [suppliesId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id])
}

model SupplyTransaction {
  id             String        @id @default(uuid())
  suppliesId     String
  userId         String?
  action         Int           @default(0)
  quantity       Int           @default(0)
  desc           String?
  timestamp      DateTime      @default(now())
  supplyBatchId  String?
  lineId         String?
  inventoryBoxId String?
  perQuantity    Int           @default(0)
  quality        String
  container      InventoryBox? @relation(fields: [inventoryBoxId], references: [id])
  line           Line?         @relation(fields: [lineId], references: [id])
  supply         Supplies      @relation(fields: [suppliesId], references: [id], onDelete: Cascade)
  list           SupplyBatch?  @relation(fields: [supplyBatchId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])
}

model SupplyIncharge {
  id               String             @id @default(uuid())
  createdAt        DateTime           @default(now())
  departmentId     String
  userId           String?
  SupplyBatchOrder SupplyBatchOrder[]
  unit             Department         @relation(fields: [departmentId], references: [id])
  user             User?              @relation(fields: [userId], references: [id])
}

model Supplies {
  id                    String                  @id @default(uuid())
  item                  String
  description           String?                 @default("N/A")
  quantity              Int                     @default(1)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  lineId                String
  userId                String?
  condition             String?                 @default("New")
  status                String?                 @default("Available")
  price                 Float                   @default(0.0)
  suppliesCategoryId    String?
  suppliesQualityId     String?
  notifyAtStockOf       Int                     @default(10)
  suppliesDataSetId     String?
  code                  Int                     @unique @default(autoincrement())
  consumable            Boolean                 @default(true)
  refNumber             String?                 @unique
  supplierId            String?
  inventoryBoxId        String?
  asset                 Assets[]
  InventoryAccessLogs   InventoryAccessLogs[]
  SupplieRecieveHistory SupplieRecieveHistory[]
  InventoryBox          InventoryBox?           @relation(fields: [inventoryBoxId], references: [id], onDelete: Cascade)
  line                  Line                    @relation(fields: [lineId], references: [id])
  Supplier              Supplier?               @relation(fields: [supplierId], references: [id])
  SuppliesCategory      SuppliesCategory?       @relation(fields: [suppliesCategoryId], references: [id])
  SuppliesDataSet       SuppliesDataSet?        @relation(fields: [suppliesDataSetId], references: [id], onDelete: Cascade)
  SuppliesQuality       SuppliesQuality?        @relation(fields: [suppliesQualityId], references: [id])
  user                  User?                   @relation(fields: [userId], references: [id])
  Part                  SuppliesRecord?         @relation("Part")
  SuppliesRecord        SuppliesRecord[]
  SupplyBatchItem       SupplyBatchItem?
  SupplyBrand           SupplyBrand[]
  supplyDispenseRecords SupplyDispenseRecord[]
  SupplyOrder           SupplyOrder[]
  SupplyOrderItemReturn SupplyOrderItemReturn[]
  SupplyPriceTrack      SupplyPriceTrack[]
  SupplyStockTrack      SupplyStockTrack[]
  supplyTransactions    SupplyTransaction[]
  TransferredSupplies   TransferredSupplies[]
}

model SupplyBrand {
  id                    String                  @id @default(uuid())
  suppliesId            String?
  timestamp             DateTime                @default(now())
  brand                 String?                 @default("N/A")
  model                 String?                 @default("N/A")
  supplyStockTrackId    String?
  supplyOrderId         String?
  supply                Supplies?               @relation(fields: [suppliesId], references: [id])
  supplyOrder           SupplyOrder?            @relation(fields: [supplyOrderId], references: [id])
  SupplyStockTrack      SupplyStockTrack?       @relation(fields: [supplyStockTrackId], references: [id], onDelete: Cascade)
  SupplyOrderItemReturn SupplyOrderItemReturn[]
}

model SupplyBatch {
  id                      String                  @id @default(uuid())
  timestamp               DateTime                @default(now())
  inventoryBoxId          String
  title                   String
  suppliesDataSetId       String?
  supplieRecieveHistories SupplieRecieveHistory[]
  box                     InventoryBox            @relation(fields: [inventoryBoxId], references: [id], onDelete: Cascade)
  SuppliesDataSet         SuppliesDataSet?        @relation(fields: [suppliesDataSetId], references: [id])
  SupplyBatchAccess       SupplyBatchAccess[]
  SupplyBatchItem         SupplyBatchItem[]
  SupplyBatchOrder        SupplyBatchOrder[]
  supplyDispenseRecords   SupplyDispenseRecord[]
  SupplyStockTrack        SupplyStockTrack[]
  supplyTransactions      SupplyTransaction[]
}

model SupplyBatchAccess {
  id            String      @id @default(uuid())
  supplyBatchId String
  userId        String
  timestamp     DateTime    @default(now())
  privilege     Int         @default(0)
  batch         SupplyBatch @relation(fields: [supplyBatchId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupplyBatchItem {
  id            String      @id @default(uuid())
  supplyBatchId String
  suppliesId    String?     @unique
  timestamp     DateTime    @default(now())
  supply        Supplies?   @relation(fields: [suppliesId], references: [id])
  batch         SupplyBatch @relation(fields: [supplyBatchId], references: [id])
}

model SupplyBatchOrder {
  id                   String                   @id @default(uuid())
  timestamp            DateTime                 @default(now())
  userId               String?
  status               Int                      @default(0)
  lineId               String?
  inventoryBoxId       String?
  title                String?                  @default("N/A")
  refNumber            String                   @unique
  supplyBatchId        String?
  approvedAt           DateTime? // Date Completed
  supplyInchargeId     String?
  comments             String                   @default("N/A")
  remark               Int                      @default(0)
  InventoryBox         InventoryBox?            @relation(fields: [inventoryBoxId], references: [id], onDelete: Cascade)
  line                 Line?                    @relation(fields: [lineId], references: [id])
  batch                SupplyBatch?             @relation(fields: [supplyBatchId], references: [id])
  inventoryInCharge    SupplyIncharge?          @relation(fields: [supplyInchargeId], references: [id])
  user                 User?                    @relation(fields: [userId], references: [id])
  order                SupplyOrder[]
  supplyOrderRecieveds SupplyOrderRecieved[]
  SupplyOrderReturn    SupplyOrderReturn[]
  files                SupplyOrderSupportFile[]
}

model Supplier {
  id                      String                  @id @default(cuid())
  name                    String                  @unique
  timestamp               DateTime                @default(now())
  lineId                  String
  supplieRecieveHistories SupplieRecieveHistory[]
  line                    Line                    @relation(fields: [lineId], references: [id])
  supplies                Supplies[]
  SupplyOrder             SupplyOrder[]
  SupplyStockTrack        SupplyStockTrack[]
}

model SupplyOrderSupportFile {
  id                 String            @id @default(uuid())
  assetsId           String
  supplyBatchOrderId String?
  file               Assets            @relation(fields: [assetsId], references: [id])
  SupplyBatchOrder   SupplyBatchOrder? @relation(fields: [supplyBatchOrderId], references: [id])
}

model SupplyOrder {
  id                      String                 @id @default(cuid())
  supplyBatchOrderId      String?
  status                  String                 @default("Drafted")
  suppliesId              String
  quantity                Int                    @default(1)
  subject                 String?                @default("None")
  refNumber               String                 @unique
  desc                    String?                @default("None")
  condition               String?                @default("New")
  remark                  Int                    @default(1)
  timestamp               DateTime?              @default(now())
  comments                String?                @default("N/A")
  price                   Float?                 @default(0.0)
  supplierId              String?
  perQuantity             Int                    @default(1)
  quality                 String?
  receivedQuantity        Int                    @default(1)
  expiration              DateTime?
  supplieRecieveHistories SupplieRecieveHistory?
  brand                   SupplyBrand[]
  supplier                Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supply                  Supplies               @relation(fields: [suppliesId], references: [id], onDelete: Cascade)
  SupplyBatchOrder        SupplyBatchOrder?      @relation(fields: [supplyBatchOrderId], references: [id])
  SupplyOrderItemReturn   SupplyOrderItemReturn?
  SupplyOrderStatus       SupplyOrderStatus[]
}

model SupplyOrderStatus {
  id            String      @id @default(uuid())
  phase         Int         @default(0)
  supplyOrderId String
  timestamp     DateTime    @default(now())
  userId        String
  desc          String?
  order         SupplyOrder @relation(fields: [supplyOrderId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
}

model SupplyOrderReturn {
  id                 String                  @id @default(uuid())
  supplyBatchOrderId String
  status             Int                     @default(0)
  timestamp          DateTime                @default(now())
  message            String?                 @default("N/A")
  item               SupplyOrderItemReturn[]
  batchOrder         SupplyBatchOrder        @relation(fields: [supplyBatchOrderId], references: [id], onDelete: Cascade)
}

model SupplyOrderItemReturn {
  id                  String             @id @default(uuid())
  supplyOrderReturnId String?
  supplyBrandId       String?
  suppliesId          String?
  quantity            Int                @default(1)
  supplyOrderId       String?            @unique
  supply              Supplies?          @relation(fields: [suppliesId], references: [id])
  brand               SupplyBrand?       @relation(fields: [supplyBrandId], references: [id])
  orderItem           SupplyOrder?       @relation(fields: [supplyOrderId], references: [id])
  SupplyOrderReturn   SupplyOrderReturn? @relation(fields: [supplyOrderReturnId], references: [id], onDelete: Cascade)
}

model SuppliesDataSet {
  id             String            @id @default(cuid())
  title          String            @unique
  timestamp      DateTime          @default(now())
  lineId         String
  inventoryBoxId String
  supplies       Supplies[]
  container      InventoryBox      @relation(fields: [inventoryBoxId], references: [id], onDelete: Cascade)
  line           Line              @relation(fields: [lineId], references: [id], onDelete: Cascade)
  unit           SuppliesQuality[]
  list           SupplyBatch[]
}

model SuppliesQuality {
  id                String             @id @default(cuid())
  quality           String             @unique
  perQuality        Int                @default(0)
  suppliesDataSetId String?
  supplies          Supplies[]
  SuppliesDataSet   SuppliesDataSet?   @relation(fields: [suppliesDataSetId], references: [id])
  supplyStockTracks SupplyStockTrack[]
}

model SupplyPriceTrack {
  id                 String            @id @default(uuid())
  value              Int               @default(0)
  suppliesId         String
  timestamp          DateTime          @default(now())
  supplyStockTrackId String?
  period             String            @default("0:0")
  supply             Supplies          @relation(fields: [suppliesId], references: [id], onDelete: Cascade)
  SupplyStockTrack   SupplyStockTrack? @relation(fields: [supplyStockTrackId], references: [id])
}

model SupplyStockTrack {
  id                   String                 @id @default(uuid())
  stock                Int                    @default(0)
  suppliesId           String
  timestamp            DateTime               @default(now())
  inventoryBoxId       String?
  supplyBatchId        String?
  expiration           DateTime?
  supplierId           String?
  perQuantity          Int                    @default(0)
  quantity             Int                    @default(0)
  suppliesQualityId    String?
  supplyStockQualityId String?
  supplyCategoryId     String?
  quality              String?
  desc                 String?                @default("N/A")
  address              String?
  col                  String?
  container            String?
  rack                 String?
  row                  String?
  brand                SupplyBrand[]
  SupplyDispenseRecord SupplyDispenseRecord[]
  price                SupplyPriceTrack[]
  inventoryBox         InventoryBox?          @relation(fields: [inventoryBoxId], references: [id], onDelete: Cascade)
  supplier             Supplier?              @relation(fields: [supplierId], references: [id])
  supply               Supplies               @relation(fields: [suppliesId], references: [id], onDelete: Cascade)
  suppliesQuality      SuppliesQuality?       @relation(fields: [suppliesQualityId], references: [id])
  list                 SupplyBatch?           @relation(fields: [supplyBatchId], references: [id], onDelete: Cascade)
  category             SupplyCategory?        @relation(fields: [supplyCategoryId], references: [id])
}

model SupplyCategory {
  id                String             @id @default(uuid())
  label             String
  timestamp         DateTime           @default(now())
  supplyStockTracks SupplyStockTrack[]
}

model SupplyDispenseRecord {
  id                 String            @id @default(uuid())
  refCode            String?           @unique
  // Idempotency key for offline desktop dispenses: a retried push with the
  // same clientOpId is detected and skipped so stock is never deducted twice.
  clientOpId         String?           @unique
  userId             String?
  departmentId       String?
  quantity           String            @default("0")
  supplyStockTrackId String?
  timestamp          DateTime          @default(now())
  remarks            String            @default("N/A")
  suppliesId         String?
  dispensaryId       String?
  inventoryBoxId     String?
  supplyBatchId      String?
  updatedAt          DateTime?
  desc               String?           @default("N/A")
  unit               Department?       @relation(fields: [departmentId], references: [id])
  dispensary         User?             @relation("dispensary", fields: [dispensaryId], references: [id])
  containerId        InventoryBox?     @relation(fields: [inventoryBoxId], references: [id], onDelete: Cascade)
  supplyItem         Supplies?         @relation(fields: [suppliesId], references: [id])
  list               SupplyBatch?      @relation(fields: [supplyBatchId], references: [id], onDelete: Cascade)
  supply             SupplyStockTrack? @relation(fields: [supplyStockTrackId], references: [id], onDelete: SetDefault)
  user               User?             @relation("supplyRecipeint", fields: [userId], references: [id], onDelete: SetDefault)
}

model SuppliesCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  supplies    Supplies[]
}

model SupplyOrderRecieved {
  id                 String                  @id @default(uuid())
  supplyBatchOrderId String
  timestamp          DateTime                @default(now())
  items              SupplieRecieveHistory[]
  order              SupplyBatchOrder        @relation(fields: [supplyBatchOrderId], references: [id])
}

model SupplieRecieveHistory {
  id                    String               @id @default(uuid())
  // Idempotency key for offline desktop restocks: a retried POST /supply/restock
  // carrying the same clientOpId is detected and skipped so stock (and this
  // receive-history row the reports depend on) is never applied twice.
  clientOpId            String?              @unique
  suppliesId            String?
  timestamp             DateTime             @default(now())
  quantity              Int                  @default(0)
  condition             String?              @default("New")
  perQuantity           Int                  @default(0)
  pricePerItem          Float                @default(0.0)
  quality               String?              @default("Box")
  supplyOrderId         String?              @unique
  supplyOrderRecievedId String?
  supplierId            String?
  supplyBatchId         String?
  inventoryBoxId        String?
  inventoryBox          InventoryBox?        @relation(fields: [inventoryBoxId], references: [id], onDelete: Cascade)
  supplier              Supplier?            @relation(fields: [supplierId], references: [id])
  supply                Supplies?            @relation(fields: [suppliesId], references: [id], onDelete: Cascade)
  list                  SupplyBatch?         @relation(fields: [supplyBatchId], references: [id], onDelete: Cascade)
  supplyOrder           SupplyOrder?         @relation(fields: [supplyOrderId], references: [id])
  supplyOrderRecieved   SupplyOrderRecieved? @relation(fields: [supplyOrderRecievedId], references: [id])
}

model TransferredSupplies {
  id              String    @id @default(uuid())
  suppliesId      String?
  userId          String
  transferredToId String
  timestamp       DateTime  @default(now())
  condition       Int       @default(1)
  supply          Supplies? @relation(fields: [suppliesId], references: [id])
  transferredTo   User      @relation("transferTo", fields: [transferredToId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
}

model SuppliesRecord {
  id          String    @id @default(uuid())
  suppliesId  String
  timestamp   DateTime  @default(now())
  userId      String
  action      String
  description String?
  modifiedId  String?   @unique
  status      Int       @default(1)
  modified    Supplies? @relation("Part", fields: [modifiedId], references: [id])
  suppyId     Supplies  @relation(fields: [suppliesId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
}

model MessageTemplate {
  id          String        @id @default(uuid())
  module      Int
  platform    String?
  message     String
  subject     String
  link        String?
  timestamp   DateTime      @default(now())
  lineId      String
  messageIv   String?
  subjectIv   String
  MessageLogs MessageLogs[]
  line        Line          @relation(fields: [lineId], references: [id])
}

model MessageLogs {
  id                String          @id @default(uuid())
  ref               String?
  number            String
  content           String?
  timestamp         DateTime?       @default(now())
  messageTemplateId String
  status            Int             @default(0)
  template          MessageTemplate @relation(fields: [messageTemplateId], references: [id])
}

model Application {
  id        String   @id @default(uuid())
  userId    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobPostId String?
  lineId    String
  jobPost   JobPost? @relation(fields: [jobPostId], references: [id])
  line      Line     @relation(fields: [lineId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubmittedApplication {
  id                      String                    @id @default(uuid())
  lastname                String
  firstname               String
  middleName              String?                   @default("N/A")
  suffix                  String?                   @default("N/A")
  birthDate               String
  email                   String
  gender                  String
  filipino                Boolean
  dualCitizen             Boolean
  byBirth                 Boolean
  byNatural               Boolean
  cvilStatus              String
